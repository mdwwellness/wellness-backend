# Copy this file to ".env" and fill in real values. Never commit the real .env.

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string for your MongoDB Atlas cluster (or local instance).
# Atlas: Database → Connect → Drivers. Remember to allow Render's IP
# (Network Access → 0.0.0.0/0) since Render free tier has no fixed IP.
DATABASE_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# Long, random, and DIFFERENT from each other. Used to sign/verify login tokens.
# Generate e.g. with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# The frontend origin allowed to call this API (no trailing slash).
# e.g. https://wellness.mydawaiwala.com  (use http://localhost:3000 for local dev)
FRONT_END_URL=http://localhost:3000

# ── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" on Render so auth cookies are marked Secure (HTTPS-only).
NODE_ENV=development

# Render injects PORT automatically — only set this for local runs if you want
# a fixed port. The server falls back to 10000.
PORT=10000
